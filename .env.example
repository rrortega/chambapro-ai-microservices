# AI Configuration
# Embeddings
AI_EMBEDDINGS_PROVIDER=local
AI_EMBEDDINGS_LOCAL_URL=http://embeddings:80/v1/embeddings
AI_EMBEDDINGS_EXTERNAL_URL=https://api.openai.com/v1/embeddings
AI_EMBEDDINGS_EXTERNAL_API_KEY=sk-your-openai-key
AI_EMBEDDINGS_EXTERNAL_MODEL=text-embedding-3-small

# Translation
AI_TRANSLATION_PROVIDER=local
AI_TRANSLATION_LOCAL_URL=http://translator:8000/v1/translations
AI_TRANSLATION_EXTERNAL_URL=https://api.openai.com/v1/chat/completions
AI_TRANSLATION_EXTERNAL_API_KEY=sk-your-openai-key
AI_TRANSLATION_EXTERNAL_MODEL=gpt-4o-mini
AI_TRANSLATION_CACHE_TTL=86400

# Security
INTERNAL_AI_API_KEY=secreto_interno
GLOBAL_API_KEY=chambapro_global_key

# Telemetry (OpenTelemetry)
ENABLE_TELEMETRY=false
OTEL_SERVICE_NAME=chambapro-ai-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/metrics
REDIS_URL=redis://redis:6379
OPENAI_API_KEY=your_openai_api_key_here
